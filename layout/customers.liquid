<!doctype html>
<html lang='{{ request.locale.iso_code | default: shop.locale }}'>
  <head>
    <title>{{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge,chrome=1'>
    <meta
      name='viewport'
      content='width=device-width,initial-scale=1,shrink-to-fit=no'
    >
    <meta name='description' content='{{ page_description | default: shop.name | escape }}'>
    <meta name='robots' content='noindex,nofollow'>
    <link rel='canonical' href='{{ canonical_url }}'>

    <link rel='preconnect' href='https://cdn.shopify.com' crossorigin>
    <link rel='preconnect' href='https://cdn.jsdelivr.net' crossorigin>
    <link rel='preconnect' href='https://unpkg.com' crossorigin>
    <link rel='dns-prefetch' href='https://cdn.shopify.com'>

    {{ content_for_header }}
    <!-- Header hook for plugins -->
    {{ "application.css" | asset_url | stylesheet_tag }}
    <script src='{{ application.js | asset_url }}' defer></script>
    <script
      defer
      src='https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js'
    ></script>

    <!-- Swiper JS -->
    <script
      src='https://cdn.jsdelivr.net/npm/swiper@11/swiper-element-bundle.min.js'
      defer
    ></script>

    <style>
      [x-cloak] {
        display: none;
      }
    </style>
  </head>
  <body>
    {% section "header" %}
    <main role='main'>
      {{ content_for_layout }}
    </main>
  </body>
</html>
