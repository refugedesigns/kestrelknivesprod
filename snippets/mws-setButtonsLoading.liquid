<script>
function mwApoCustom() {
  window.mwApoInit = window.mwApoInit || {};

  function getApoButtons() {
    return document.querySelectorAll(
      ".mw-apo-add-to-cart-cloned, #stickyAddToCartBtn"
    );
  }

  function setButtonsLoading() {
    console.log('setButtonsLoading setButtonsLoading')
    getApoButtons().forEach(function (btn) {
      btn.dataset.originalText = btn.dataset.originalText || btn.textContent.trim() || "ADD TO CART";
      btn.innerHTML = "";
      btn.classList.add("mw-apo-in-progress");
      btn.disabled = true;
      btn.setAttribute("aria-busy", "true");
    });
  }

  function resetButtons() {
    getApoButtons().forEach(function (btn) {
      const text = btn.dataset.originalText || "ADD TO CART";

      btn.classList.remove("mw-apo-in-progress");
      btn.innerHTML = text;
      btn.disabled = false;
      btn.setAttribute("aria-busy", "false");
    });
  }

  window.mwApoInit.onEvent = function (event, args) {
    if (event === "attachEvents::initAddToCart::clickStart") {
      setButtonsLoading();
    }

    if (event === "onClick::validate-failed") {
      resetButtons();
    }

    if (event === "attachEvents::initAddToCart::clickFinally") {
      setTimeout(function () {
        resetButtons();
      }, 500);
    }
  };

  window.mwApoInit.onCallback = function (event, data) {
    return data;
  };
}
</script>

<style>
  .mw-apo-in-progress {
    position: relative;
  }

  .mw-apo-in-progress::after {
    content: "";
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: mwApoSpin 1s ease-in-out infinite;
  }

  @keyframes mwApoSpin {
    to {
      transform: rotate(360deg);
    }
  }
</style>