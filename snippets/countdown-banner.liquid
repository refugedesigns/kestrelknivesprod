{% if section.settings.countdown_enabled %}
  <div x-data='countdownBanner()' x-init='init()'>
    <style>
      .countdown-drawer {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: #000;
        color: #fff;
        transform: translateY(-100%);
        opacity: 0;
        pointer-events: none;
        transition: transform 0.3s ease, opacity 0.3s ease;
      }
      .countdown-drawer.is-open {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      #countdownBanner {
        width: 100%;
        max-width: 100vw;
        overflow: visible;
      }

      .countdown-banner__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding-block: 0.5rem;
        text-align: center;
      }

      .countdown-banner__content {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.375rem 0.5rem;
        width: 100%;
        min-width: 0;
      }

      .countdown-banner__timer {
        flex-shrink: 0;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
      }

      .countdown-banner__title {
        min-width: 0;
        line-height: 1.25;
      }

      .countdown-banner__action {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 100%;
      }

      .countdown-banner__button {
        display: inline-block;
        max-width: 100%;
        text-align: center;
        line-height: 1.25;
        white-space: normal;
        word-break: break-word;
      }

      @media (min-width: 640px) {
        .countdown-banner__inner {
          flex-direction: row;
          gap: 1rem;
        }

        .countdown-banner__content {
          flex: 1 1 auto;
          justify-content: center;
        }

        .countdown-banner__title {
          white-space: nowrap;
        }

        .countdown-banner__action {
          width: auto;
          flex-shrink: 0;
        }

        .countdown-banner__button {
          white-space: nowrap;
        }
      }
    </style>
    <div
      id='countdownBanner'
      class='fixed top-0 left-0 right-0 z-30 transition-transform duration-300'
      style='background-color: {{ section.settings.countdown_bg_color | default: "#000000" }};'
    >
      <div class='mx-auto px-2 sm:px-4 lg:px-6 max-w-8xl'>
        <div class='countdown-banner__inner'>
          <div
            class='countdown-banner__content'
            style='color: {{ section.settings.countdown_text_color | default: "#ffffff" }};'
          >
            {% if section.settings.countdown_show_timer != false %}
              <span
                class='countdown-banner__timer text-[11px] sm:text-sm font-medium'
                x-text='formattedTime'
              ></span>
            {% endif %}
            {% if section.settings.countdown_title != blank %}
              <span
                class='countdown-banner__title text-[11px] sm:text-sm font-bold'
                style='color: {{ section.settings.countdown_text_color | default: "#ffffff" }};'
              >
                {{ section.settings.countdown_title }}
              </span>
            {% endif %}
          </div>
          {% if section.settings.notify_button_action == "link"
            and section.settings.notify_button_link != blank
          %}
            <div class='countdown-banner__action'>
              <a
                href='{{ section.settings.notify_button_link }}'
                class='countdown-banner__button px-3 sm:px-4 py-1 sm:py-1.5 text-[11px] sm:text-sm font-medium transition-colors hover:opacity-90 no-underline'
                style='background-color: {{ section.settings.notify_button_bg_color | default: "#ea580c" }}; color: {{ section.settings.notify_button_text_color | default: "#ffffff" }};'
              >
                {{ section.settings.notify_button_text | default: "NOTIFY ME" }}
              </a>
            </div>
          {% else %}
            <div class='countdown-banner__action'>
              <button
                type='button'
                onclick='openCountdownDrawer()'
                class='countdown-banner__button px-3 sm:px-4 py-1 sm:py-1.5 text-[11px] sm:text-sm font-medium transition-colors hover:opacity-90'
                style='background-color: {{ section.settings.notify_button_bg_color | default: "#ea580c" }}; color: {{ section.settings.notify_button_text_color | default: "#ffffff" }};'
              >
                {{ section.settings.notify_button_text | default: "NOTIFY ME" }}
              </button>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- Notification Drawer -->
    <div
      id='countdownDrawer'
      class='countdown-drawer'
      onclick='if (event.target === this) closeCountdownDrawer()'
    >
      <div class='relative w-full'>
        <button
          onclick='closeCountdownDrawer()'
          class='absolute right-4 top-4 text-white hover:text-gray-300 transition-colors'
          aria-label='Close'
        >
          <svg
            class='w-6 h-6'
            fill='none'
            stroke='currentColor'
            viewBox='0 0 24 24'
          >
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M6 18L18 6M6 6l12 12'/>
          </svg>
        </button>
        <div class='max-w-2xl mx-auto px-4 sm:px-6 py-8'>
          <div class='klaviyo-form-QReqgv hidden lg:block'></div>
          <div class='klaviyo-form-XV8rPN lg:hidden'></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function countdownBanner() {
      return {
        days: 0,
        hours: 0,
        minutes: 0,
        seconds: 0,
        init() {
          this.startCountdown()
          this.setupScrollBehavior()
          this.updateBannerHeight()
          window.addEventListener('resize', () => this.updateBannerHeight())

          const banner = document.getElementById('countdownBanner')
          if (banner && 'ResizeObserver' in window) {
            const bannerResizeObserver = new ResizeObserver(() =>
              this.updateBannerHeight()
            )
            bannerResizeObserver.observe(banner)
          }
        },

        updateBannerHeight() {
          const banner = document.getElementById('countdownBanner')
          if (banner) {
            const height = banner.offsetHeight
            document.documentElement.style.setProperty(
              '--countdown-banner-height',
              height + 'px'
            )
          }
        },

        setupScrollBehavior() {
          const banner = document.getElementById('countdownBanner')
          const header = document.getElementById('siteHeader')
          if (!banner || !header) return

          let ticking = false
          const handleScroll = () => {
            if (!ticking) {
              window.requestAnimationFrame(() => {
                const scrollTop =
                  window.pageYOffset || document.documentElement.scrollTop
                const bannerHeight = banner.offsetHeight

                if (scrollTop > bannerHeight) {
                  banner.style.transform = 'translateY(-100%)'
                  header.style.top = '0'
                } else {
                  banner.style.transform = 'translateY(0)'
                  header.style.top = bannerHeight + 'px'
                }
                ticking = false
              })
              ticking = true
            }
          }
          window.addEventListener('scroll', handleScroll, { passive: true })
        },

        normalizeTargetDate() {
          let targetDateString =
            '{{ section.settings.countdown_target_date | default: "2025-12-31T23:59:59" }}'
          let cleanDateString = targetDateString.trim()

          if (!cleanDateString.includes('T')) {
            cleanDateString += 'T23:59:59'
          }

          if (
            !cleanDateString.includes('Z') &&
            !cleanDateString.includes('+') &&
            !cleanDateString.includes('-', 10)
          ) {
            cleanDateString += 'Z'
          }

          return new Date(cleanDateString).getTime()
        },

        startCountdown() {
          const updateCountdown = () => {
            const targetDate = this.normalizeTargetDate()
            const now = new Date().getTime()
            const distance = targetDate - now

            if (distance < 0) {
              this.days = this.hours = this.minutes = this.seconds = 0
              return
            }

            this.days = Math.floor(distance / (1000 * 60 * 60 * 24))
            this.hours = Math.floor(
              (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)
            )
            this.minutes = Math.floor(
              (distance % (1000 * 60 * 60)) / (1000 * 60)
            )
            this.seconds = Math.floor((distance % (1000 * 60)) / 1000)
          }
          updateCountdown()
          setInterval(updateCountdown, 1000)
        },

        get formattedTime() {
          const pad = n => String(n).padStart(2, '0')
          return `${pad(this.days)}:${pad(this.hours)}:${pad(this.minutes)}:${pad(this.seconds)}`
        },

        openDrawer() {},
        closeDrawer() {},
      }
    }

    function openCountdownDrawer() {
      const drawer = document.getElementById('countdownDrawer')
      if (!drawer) return
      drawer.classList.add('is-open')
      document.body.style.overflow = 'hidden'
    }

    function closeCountdownDrawer() {
      const drawer = document.getElementById('countdownDrawer')
      if (!drawer) return
      drawer.classList.remove('is-open')
      document.body.style.overflow = ''
    }
  </script>
{% endif %}
