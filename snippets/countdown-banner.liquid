{% if section.settings.countdown_enabled %}
<div x-data='countdownBanner()' x-init='init()'>
  <div
    id='countdownBanner'
    class='fixed top-0 left-0 right-0 z-30 transition-transform duration-300'
    style='background-color: {{ section.settings.countdown_bg_color | default: "#000000" }}; border-bottom: 2px solid {{ section.settings.countdown_border_color | default: "#dc2626" }};'
  >
    <div class='mx-auto px-4 sm:px-6 max-w-8xl'>
      <div class='flex items-center justify-center py-2 space-x-4 text-center'>
        {% if section.settings.countdown_title != blank %}
          <span
            class='text-white text-xs sm:text-sm font-bold whitespace-nowrap'
            style='color: {{ section.settings.countdown_text_color | default: "#ffffff" }};'
          >
            {{ section.settings.countdown_title }}
          </span>
        {% endif %}
        <span
          class='text-white text-xs sm:text-sm font-medium whitespace-nowrap flex items-center space-x-2'
          style='color: {{ section.settings.countdown_text_color | default: "#ffffff" }};'
        >
          <span x-text='formattedTime'></span>
          <span>{{ section.settings.countdown_text | default: "UNTIL THE NEXT BLADE DROP:" }}</span>
        </span>
        <button
          @click='openDrawer()'
          class='ml-4 px-4 py-1.5 text-sm font-medium text-white whitespace-nowrap transition-colors hover:opacity-90'
          style='background-color: {{ section.settings.notify_button_bg_color | default: "#ea580c" }}; color: {{ section.settings.notify_button_text_color | default: "#ffffff" }};'
        >
          {{ section.settings.notify_button_text | default: "NOTIFY ME" }}
        </button>
      </div>
    </div>
  </div>

  <!-- Notification Drawer -->
  <div
    x-show='drawerOpen'
    x-transition:enter='transition ease-out duration-300'
    x-transition:enter-start='opacity-0 translate-y-[-100%]'
    x-transition:enter-end='opacity-100 translate-y-0'
    x-transition:leave='transition ease-in duration-200'
    x-transition:leave-start='opacity-100 translate-y-0'
    x-transition:leave-end='opacity-0 translate-y-[-100%]'
    @click.away='closeDrawer()'
    class='fixed top-0 left-0 right-0 z-50 bg-black text-white'
    style='display: none; padding-top: var(--countdown-banner-height, 40px);'
  >
    <div class='max-w-2xl mx-auto px-4 sm:px-6 py-8'>
      <div class='flex items-center justify-between mb-6'>
        <h2 class='text-2xl md:text-3xl font-bold text-center w-full'>Never Miss Another Drop!</h2>
        <button
          @click='closeDrawer()'
          class='text-white hover:text-gray-300 transition-colors absolute right-4 top-6'
        >
          <svg
            class='w-6 h-6'
            fill='none'
            stroke='currentColor'
            viewBox='0 0 24 24'
          >
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M6 18L18 6M6 6l12 12'/>
          </svg>
        </button>
      </div>
      
      <p class='text-gray-300 mb-6 text-center'>
        Sign up for the next launch by entering your email below!
      </p>
      
      <form
        @submit.prevent='submitForm()'
        class='flex flex-col sm:flex-row gap-3'
      >
        <input
          type='email'
          x-model='email'
          placeholder='EMAIL ADDRESS'
          required
          class='flex-1 px-4 py-3 bg-gray-800 text-white placeholder-gray-400 border border-gray-700 rounded focus:outline-none focus:ring-2 focus:ring-orange-500'
        >
        <button
          type='submit'
          :disabled='isSubmitting'
          class='px-6 py-3 font-medium text-white rounded transition-colors disabled:opacity-50'
          style='background-color: {{ section.settings.notify_button_bg_color | default: "#ea580c" }};'
        >
          <span x-show='!isSubmitting'>SIGN UP</span>
          <span x-show='isSubmitting'>SIGNING UP...</span>
        </button>
      </form>
      
      <div
        x-show='submitMessage'
        x-text='submitMessage'
        :class='submitSuccess ? "text-green-400 text-center" : "text-red-400 text-center"'
        class='mt-4 text-sm'
      ></div>
    </div>
  </div>
</div>

<script>
  function countdownBanner() {
    return {
      days: 0,
      hours: 0,
      minutes: 0,
      seconds: 0,
      drawerOpen: false,
      email: '',
      isSubmitting: false,
      submitMessage: '',
      submitSuccess: false,
      
      init() {
        this.startCountdown()
        this.setupScrollBehavior()
        this.updateBannerHeight()
        
        // Update banner height on resize
        window.addEventListener('resize', () => this.updateBannerHeight())
      },
      
      updateBannerHeight() {
        const banner = document.getElementById('countdownBanner')
        if (banner) {
          const height = banner.offsetHeight
          document.documentElement.style.setProperty('--countdown-banner-height', height + 'px')
        }
      },
      
      setupScrollBehavior() {
        const banner = document.getElementById('countdownBanner')
        const header = document.getElementById('siteHeader')
        
        if (!banner || !header) return
        
        let ticking = false
        
        const handleScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              const scrollTop = window.pageYOffset || document.documentElement.scrollTop
              const bannerHeight = banner.offsetHeight
              
              if (scrollTop > bannerHeight) {
                // Hide banner when scrolled past it
                banner.style.transform = 'translateY(-100%)'
                // Header sticks to top
                header.style.top = '0'
              } else {
                // Show banner when at top
                banner.style.transform = 'translateY(0)'
                // Header positioned below banner
                header.style.top = bannerHeight + 'px'
              }
              
              ticking = false
            })
            
            ticking = true
          }
        }
        
        window.addEventListener('scroll', handleScroll, { passive: true })
      },
      
      startCountdown() {
        // Get target date from settings or use a default
        const targetDate = new Date('{{ section.settings.countdown_target_date | default: "2025-12-31T23:59:59" }}').getTime()
        
        const updateCountdown = () => {
          const now = new Date().getTime()
          const distance = targetDate - now
          
          if (distance < 0) {
            this.days = 0
            this.hours = 0
            this.minutes = 0
            this.seconds = 0
            return
          }
          
          this.days = Math.floor(distance / (1000 * 60 * 60 * 24))
          this.hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
          this.minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60))
          this.seconds = Math.floor((distance % (1000 * 60)) / 1000)
        }
        
        updateCountdown()
        setInterval(updateCountdown, 1000)
      },
      
      get formattedTime() {
        const pad = (n) => String(n).padStart(2, '0')
        return `${pad(this.days)}:${pad(this.hours)}:${pad(this.minutes)}:${pad(this.seconds)}`
      },
      
      openDrawer() {
        this.drawerOpen = true
        document.body.style.overflow = 'hidden'
      },
      
      closeDrawer() {
        this.drawerOpen = false
        document.body.style.overflow = ''
      },
      
      async submitForm() {
        if (!this.email || this.isSubmitting) return
        
        this.isSubmitting = true
        this.submitMessage = ''
        this.submitSuccess = false
        
        try {
          // Use Shopify contact form API
          const formData = new URLSearchParams({
            'form_type': 'customer',
            'utf8': '✓',
            'contact[email]': this.email,
            'contact[tags]': 'countdown-notification',
          })
          
          const response = await fetch('/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: formData,
          })
          
          if (response.ok) {
            this.submitSuccess = true
            this.submitMessage = 'Thank you! You\'ll be notified when the drop goes live.'
            this.email = ''
            
            // Close drawer after 3 seconds
            setTimeout(() => {
              this.closeDrawer()
              this.submitMessage = ''
              this.submitSuccess = false
            }, 3000)
          } else {
            throw new Error('Submission failed')
          }
        } catch (error) {
          console.error('Form submission error:', error)
          this.submitSuccess = false
          this.submitMessage = 'Something went wrong. Please try again.'
        } finally {
          this.isSubmitting = false
        }
      },
    }
  }
</script>
{% endif %}

