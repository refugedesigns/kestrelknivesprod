<!-- Hero Carousel Section -->
<style>
  .hero-root {
    min-height: {{ section.settings.hero_height_px | default: 600 }}px;
  }

  .hero-scale-wrap,
  .hero-swiper {
    min-height: inherit;
  }

  .hero-overlay {
    padding-bottom: 3rem;
  }

  .hero-overlay .hero-overlay__inner {
    margin-bottom: 3rem;
  }

  @media (max-width: 1023px) {
    .hero-overlay {
      padding-top: calc(var(--header-height, 64px) + 16px);
      padding-bottom: var(--hero-mobile-overlay-padding-bottom, 12px);
      flex-direction: column !important;
      align-items: center !important;
      justify-content: flex-start !important;
      top: 0 !important;
      bottom: 0 !important;
    }

    .hero-overlay .hero-overlay__inner {
      position: relative !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-start !important;
      flex: 1 1 auto !important;
      width: 100% !important;
      min-height: 100% !important;
      margin-left: 0 !important;
      margin-bottom: 0 !important;
      padding-top: var(--hero-mobile-text-padding-top, 0px);
      padding-bottom: calc(
        var(--hero-mobile-button-margin-bottom, 12px) + 3.5rem
      );
      text-align: center !important;
    }

    .hero-overlay .kk-text-wrap {
      flex-shrink: 0;
    }

    .hero-root .hero-slide-button-wrap {
      position: absolute !important;
      left: 0 !important;
      right: 0 !important;
      bottom: var(--hero-mobile-button-margin-bottom, 12px) !important;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
      flex-shrink: 0;
    }

    .hero-root .kk-text-content {
      margin-top: 0 !important;
      padding-top: 0 !important;
    }
  }
</style>
<div class='relative hero-root'>
  <div
    class='hero-scale-wrap'
    style='--hero-height-desktop: {{ section.settings.hero_height_px | default: 600 }}px; --hero-scale: {{ section.settings.scale_percent | default: 100 }}; --hero-scale-inv: {{ 10000 | divided_by: section.settings.scale_percent | times: 0.01 }}; --hero-radius: {% if section.settings.scale_percent and section.settings.scale_percent < 100 %}{{ section.settings.scale_radius | default: 16 }}px{% else %}0px{% endif %}; --hero-height-mobile: {{ section.settings.hero_height_mobile_px | default: 420 }}px; --hero-mobile-overlay-padding-bottom: {{ section.settings.hero_mobile_overlay_padding_bottom | default: 12 }}px; --hero-mobile-overlay-inner-margin-bottom: {{ section.settings.hero_mobile_overlay_inner_margin_bottom | default: 28 }}px; --hero-mobile-button-margin-top: {{ section.settings.hero_mobile_button_margin_top | default: 16 }}px; --hero-mobile-button-margin-bottom: {{ section.settings.hero_mobile_button_margin_bottom | default: 12 }}px; --hero-mobile-text-padding-top: {{ section.settings.hero_mobile_text_padding_top | default: 0 }}px;'
  >
    {% liquid
      assign hero_mode = section.settings.hero_mode | default: 'carousel'
      assign single_slide_num = section.settings.single_hero_slide_number | default: 1
      assign slide_counter = 0
    %}
    <swiper-container
      class='hero-swiper'
      style='--swiper-theme-color: #ffffff;'
      pagination='{% if hero_mode == "carousel" %}true{% else %}false{% endif %}'
      pagination-clickable='{% if hero_mode == "carousel" %}true{% else %}false{% endif %}'
      navigation='false'
      space-between='0'
      centered-slides='true'
      {% if hero_mode == 'carousel' %}
        autoplay-delay='{{ section.settings.slider_autoplay_delay | default: 5 | times: 1000 }}'
        autoplay-disable-on-interaction='false'
        loop='true'
      {% else %}
        loop='false'
        allow-touch-move='false'
      {% endif %}
      auto-height='true'
    >
      {% for block in section.blocks %}
        {% if block.type != 'slide' %}{% continue %}{% endif %}
        {% assign slide_counter = slide_counter | plus: 1 %}
        {% if hero_mode == 'single' and slide_counter != single_slide_num %}{% continue %}{% endif %}
        {% render 'hero-slide', block: block, section: section %}
      {% endfor %}
    </swiper-container>
  </div>
</div>

<script type='text/javascript'>
  function attachKlaviyoFormTrigger(selector) {
    var elements = document.querySelectorAll(selector)
    if (!elements.length) return
    elements.forEach(function (el) {
      el.addEventListener('click', function (event) {
        event.preventDefault()
        var formId = el.getAttribute('data-klaviyo-form-id')
        if (!formId) return
        window._klOnsite = window._klOnsite || []
        window._klOnsite.push(['openForm', formId])
      })
    })
  }

  attachKlaviyoFormTrigger('.hero-slide-button[data-klaviyo-form-id]')
  attachKlaviyoFormTrigger('.hero-slide-media[data-klaviyo-form-id]')
</script>

<!-- Swiper Styles -->
<style>
  .hero-swiper {
    width: 100%;
    height: auto;
    border-radius: var(--hero-radius, 0px);
    overflow: hidden;
  }

  .hero-scale-wrap {
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: var(--hero-radius, 0px);
  }

  .hero-scale-wrap .hero-swiper {
    transform: scale(calc(var(--hero-scale, 100) / 100));
    transform-origin: center center;
  }

  .hero-swiper swiper-slide {
    height: auto;
    width: 100%;
    overflow: visible;
    display: flex;
    justify-content: center;
    align-items: stretch;
    position: relative;
    text-align: center;
    font-size: 18px;
  }

  .hero-slide-media {
    width: 100%;
    aspect-ratio: var(--slide-aspect-desktop, 1.7778);
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: var(--hero-radius, 0px);
  }
  .hero-slide-media-button {
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    text-align: inherit;
  }
  .hero-slide-button-wrap {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 1024px) {
    .hero-slide-button-wrap {
      margin-top: 1rem;
    }
  }

  .hero-slide-media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-slide-media img {
    border-radius: inherit;
    transform-origin: center center;
    width: 100%;
    height: 100%;
    display: block;
  }

  .kk-text-wrap { position: relative; }
  .kk-text-bg {
    position: absolute;
    inset: -0.5rem;
    border-radius: 0.5rem;
    z-index: -1;
  }
  .kk-text-content { position: relative; z-index: 1; }

  @media (max-width: 1024px) {
    .hero-slide-media {
      aspect-ratio: var(--slide-aspect-tablet, var(--slide-aspect-desktop, 1.7778));
    }
  }

  @media (max-width: 768px) {
    .hero-root {
      min-height: {{ section.settings.hero_height_mobile_px | default: 520 }}px;
    }

    .hero-scale-wrap .hero-swiper {
      width: calc(100% * var(--hero-scale-inv, 1));
      transform: scale(calc(var(--hero-scale, 100) / 100));
    }
    .hero-slide-media,
    .hero-swiper swiper-slide {
      height: var(--hero-height-mobile, 420px);
      aspect-ratio: auto;
    }
  }

  {% for block in section.blocks %}
    {% if block.type == 'slide' %}
  .hero-root [data-hero-slide="{{ block.id }}"] img {
    object-fit: {{ block.settings.image_fit_desktop | default: block.settings.image_fit | default: 'cover' }};
    object-position: {{ block.settings.image_position_desktop | default: block.settings.image_position | default: 'center' }};
  }
    {% endif %}
  {% endfor %}

  @media (max-width: 1024px) {
  {% for block in section.blocks %}
    {% if block.type == 'slide' %}
    .hero-root [data-hero-slide="{{ block.id }}"] img {
      object-fit: {{ block.settings.image_fit_tablet | default: block.settings.image_fit | default: 'cover' }};
      object-position: {{ block.settings.image_position_tablet | default: block.settings.image_position | default: 'center' }};
    }
    {% endif %}
  {% endfor %}
  }

  @media (max-width: 768px) {
  {% for block in section.blocks %}
    {% if block.type == 'slide' %}
    .hero-root [data-hero-slide="{{ block.id }}"] img {
      object-fit: {{ block.settings.image_fit_mobile | default: block.settings.image_fit | default: 'cover' }};
      object-position: {{ block.settings.image_position_mobile | default: block.settings.image_position | default: 'center' }};
    }
    {% endif %}
  {% endfor %}
  }

  .hero-swiper .swiper-pagination-bullet {
    background: white !important;
    opacity: 1;
  }
  .hero-swiper .swiper-pagination-bullet-active {
    background: white !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const progressCircle = document.querySelector('.autoplay-progress svg')
    const progressContent = document.querySelector('.autoplay-progress span')

    const isDigit = value => /^[0-9]$/.test(value)
    const splitHeroTitle = title => {
      const lines = []
      let currentLine = ''

      for (let index = 0; index < title.length; index += 1) {
        const character = title.charAt(index)
        const previousCharacter = title.charAt(index - 1)
        const nextCharacter = title.charAt(index + 1)
        const isDecimalPoint =
          character === '.' &&
          isDigit(previousCharacter) &&
          isDigit(nextCharacter)

        if (character === '.' && !isDecimalPoint) {
          const trimmedLine = currentLine.trim()
          if (trimmedLine) lines.push(trimmedLine)
          currentLine = ''
        } else {
          currentLine += character
        }
      }

      const finalLine = currentLine.trim()
      if (finalLine) lines.push(finalLine)

      return lines
    }

    document.querySelectorAll('.hero-title-breaks').forEach(titleElement => {
      const title = titleElement.textContent.trim()
      const titleLines = splitHeroTitle(title)

      if (titleLines.length <= 1) {
        titleElement.textContent = title
        return
      }

      titleElement.textContent = ''
      titleLines.forEach(titleLine => {
        const lineElement = document.createElement('span')
        lineElement.className = 'block'
        lineElement.textContent = titleLine
        titleElement.appendChild(lineElement)
      })
    })

    const swiperEl = document.querySelector('.hero-swiper')
    if (swiperEl) {
      swiperEl.addEventListener('autoplaytimeleft', e => {
        const [swiper, time, progress] = e.detail
        if (progressCircle) {
          progressCircle.style.setProperty('--progress', 1 - progress)
        }
        if (progressContent) {
          progressContent.textContent = `${Math.ceil(time / 1000)}s`
        }
      })
    }
  })
</script>
