<section class='paboyz-landing bg-white'>
  <style>
    .paboyz-slider {
      width: 100%;
      height: var(--paboyz-slider-height, 320px);
      overflow: hidden;
      border-radius: 0.75rem;
    }
    .paboyz-slider swiper-slide {
      width: 100%;
      height: 100%;
    }
    .paboyz-slider img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    @media (max-width: 768px) {
      .paboyz-slider {
        height: var(--paboyz-slider-height-mobile, 240px);
      }
    }
    .paboyz-hero-text,
    .paboyz-hero-text * {
      text-align: center !important;
    }
    .paboyz-hero-subheading {
      width: 100% !important;
      max-width: 42rem !important;
      margin-left: auto !important;
      margin-right: auto !important;
    }
    .paboyz-feature-slider {
      position: relative;
    }
    .paboyz-feature-text {
      background: #fff;
    }
  </style>

  <div class='max-w-6xl mx-auto w-full px-4 py-12'>
    <div class='flex flex-row justify-between items-center gap-4 mb-16 flex-wrap'>
      <div class='flex items-center'>
        {% if section.settings.logo_right_image != blank %}
          <img
            src='{{ section.settings.logo_right_image | image_url: width: 300 }}'
            alt='{{ section.settings.logo_right_text | escape }}'
            class='object-contain'
            style='width: {{ section.settings.logo_right_size | default: 72 }}px; height: {{ section.settings.logo_right_size | default: 72 }}px;'
            loading='lazy'
          >
        {% else %}
          <span class='text-black font-bold text-lg'>
            {{ section.settings.logo_right_text }}
          </span>
        {% endif %}
      </div>
      <div class='flex items-center'>
        {% if section.settings.logo_left_image != blank %}
          <img
            src='{{ section.settings.logo_left_image | image_url: width: 300 }}'
            alt='{{ section.settings.logo_left_text | escape }}'
            class='object-contain'
            style='width: {{ section.settings.logo_left_size | default: 72 }}px; height: {{ section.settings.logo_left_size | default: 72 }}px;'
            loading='lazy'
          >
        {% else %}
          <span class='text-black font-bold text-lg'>
            {{ section.settings.logo_left_text }}
          </span>
        {% endif %}
      </div>
    </div>

    <div class='paboyz-hero-text text-center mb-8 space-y-4'>
      <h1 class='text-5xl md:text-7xl font-bold text-black leading-tight'>
        <span class='block'>{{ section.settings.hero_heading_line_1 }}</span>
        <span class='block text-black'>{{ section.settings.hero_heading_line_2 }}</span>
      </h1>
      <p class='paboyz-hero-subheading text-xl text-gray-700 text-center' style='text-align: center;'>
        {{ section.settings.hero_subheading }}
      </p>
    </div>

    <div class='max-w-md mx-auto mb-10'>
    <div class="klaviyo-form-RyAX8C"></div>
    </div>
  </div>

  <div class='border-t border-gray-200 bg-white'>
    <div class='max-w-6xl mx-auto px-4 py-8 paboyz-feature-text'>
      <div class='max-w-3xl mx-auto text-center'>
        <h2 class='text-3xl font-bold text-black mb-3'>
          {{ section.settings.feature_heading }}
        </h2>
        <p class='text-gray-700 text-lg leading-relaxed mb-4'>
          {{ section.settings.feature_text }}
        </p>
      </div>
    </div>
    <div class='paboyz-feature-slider'>
      <swiper-container
        class='paboyz-slider'
        style='--paboyz-slider-height: {{ section.settings.slider_height_desktop }}px; --paboyz-slider-height-mobile: {{ section.settings.slider_height_mobile }}px;'
        autoplay-delay='{{ section.settings.slider_autoplay_delay | default: 5000 }}'
        autoplay-disable-on-interaction='false'
        loop='true'
        pagination='true'
        pagination-clickable='true'
        slides-per-view='3'
        space-between='12'
        centered-slides='false'
        breakpoints='{"0":{"slidesPerView":1},"640":{"slidesPerView":2},"1024":{"slidesPerView":4}}'
      >
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'slider_image' %}
              <swiper-slide>
                {% if block.settings.image != blank %}
                  <img
                    src='{{ block.settings.image | image_url: width: 1200 }}'
                    alt='{{ block.settings.alt_text | escape }}'
                    loading='lazy'
                  >
                {% else %}
                  {{ "lifestyle-1" | placeholder_svg_tag: "w-full h-full bg-gray-200" }}
                {% endif %}
              </swiper-slide>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <swiper-slide>
              {{ "lifestyle-1" | placeholder_svg_tag: "w-full h-full bg-gray-200" }}
            </swiper-slide>
          {% endfor %}
        {% endif %}
      </swiper-container>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PaBoyz Outdoors Landing",
  "settings": [
    {
      "type": "header",
      "content": "Logo Badges"
    },
    {
      "type": "image_picker",
      "id": "logo_left_image",
      "label": "Left logo image"
    },
    {
      "type": "range",
      "id": "logo_left_size",
      "label": "Left logo size (px)",
      "min": 100,
      "max": 600,
      "step": 5,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "logo_left_text",
      "label": "Left logo text",
      "default": "Kestrel"
    },
    {
      "type": "image_picker",
      "id": "logo_right_image",
      "label": "Right logo image"
    },
    {
      "type": "range",
      "id": "logo_right_size",
      "label": "Right logo size (px)",
      "min": 100,
      "max": 600,
      "step": 5,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "logo_right_text",
      "label": "Right logo text",
      "default": "PaBoyz"
    },
    {
      "type": "header",
      "content": "Hero Text"
    },
    {
      "type": "text",
      "id": "hero_heading_line_1",
      "label": "Hero heading line 1",
      "default": "Win 1 of 12"
    },
    {
      "type": "text",
      "id": "hero_heading_line_2",
      "label": "Hero heading line 2",
      "default": "Kestrel Knives"
    },
    {
      "type": "textarea",
      "id": "hero_subheading",
      "label": "Hero subheading",
      "default": "Enter with your name and email for a chance to win 1 of 12 Kestrel Knives."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "form_name_label",
      "label": "Name label",
      "default": "Your Name"
    },
    {
      "type": "text",
      "id": "form_name_placeholder",
      "label": "Name placeholder",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "form_email_label",
      "label": "Email label",
      "default": "Email Address"
    },
    {
      "type": "text",
      "id": "form_email_placeholder",
      "label": "Email placeholder",
      "default": "you@example.com"
    },
    {
      "type": "text",
      "id": "form_button_text",
      "label": "Button text",
      "default": "Count Me In"
    },
    {
      "type": "text",
      "id": "form_success_heading",
      "label": "Success heading",
      "default": "You're In!"
    },
    {
      "type": "text",
      "id": "form_success_text",
      "label": "Success text",
      "default": "Your entry has been received. Good luck!"
    },
    {
      "type": "header",
      "content": "Feature Section"
    },
    {
      "type": "text",
      "id": "feature_heading",
      "label": "Feature heading",
      "default": "Premium Craftsmanship"
    },
    {
      "type": "textarea",
      "id": "feature_text",
      "label": "Feature text",
      "default": "Each Kestrel Knife is expertly crafted with precision engineering and premium materials. Built for performance and durability, these are the tools serious craftspeople depend on."
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "slider_autoplay_delay",
      "label": "Slider autoplay delay (ms)",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 5000
    },
    {
      "type": "range",
      "id": "slider_height_desktop",
      "label": "Slider height (desktop px)",
      "min": 240,
      "max": 600,
      "step": 20,
      "default": 320
    },
    {
      "type": "range",
      "id": "slider_height_mobile",
      "label": "Slider height (mobile px)",
      "min": 200,
      "max": 480,
      "step": 20,
      "default": 240
    }
  ],
  "blocks": [
    {
      "type": "slider_image",
      "name": "Slider image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PaBoyz Outdoors Landing",
      "blocks": [
        { "type": "slider_image" },
        { "type": "slider_image" },
        { "type": "slider_image" }
      ]
    }
  ]
}
{% endschema %}
