<div class='max-w-4xl mx-auto text-center mt-4 mb-4 px-4 border-b border-gray-200 pb-4'>
  <h1
    id='gear-testing-program-header'
    class='text-3xl md:text-4xl font-bold text-gray-900 mb-8'
  >
    {{ section.settings.page_title }}
  </h1>
  <div class='text-gray-700 text-sm text-left pl-4 leading-relaxed gear-testing-subtitle mt-4'>
    {{ section.settings.subtitle }}
  </div>
</div>

<style>
  /* Preserve paragraph spacing for the rich text subtitle without affecting other sections */
  .gear-testing-subtitle p {
    margin: 0 0 0.4rem;
  }
  .gear-testing-subtitle p:last-child {
    margin-bottom: 0;
  }

  .gear-testing-form-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    width: 100%;
  }
  .gear-testing-form-section__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    pointer-events: none;
  }
  .gear-testing-form-section__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, 0.35);
    pointer-events: none;
  }
  .gear-testing-form-section__content {
    position: relative;
    z-index: 2;
    max-width: 56rem;
    margin-left: auto;
    margin-right: auto;
    margin-top: 10px;
    margin-bottom: 10px;
    padding: 2rem;
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    overflow: visible;
    pointer-events: auto;
  }
  .gear-testing-form-section__content::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: rgba(255, 255, 255, 0.4);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    pointer-events: none;
  }
  .gear-testing-form-section__form {
    position: relative;
    z-index: 1;
    width: 100%;
    pointer-events: auto;
  }
  .gear-testing-form-section__form.pifyform,
  .gear-testing-form-section__form.pifyform iframe {
    position: relative;
    z-index: 1;
    pointer-events: auto;
  }
  .gear-testing-form-section__form.pifyform.formloading iframe {
    visibility: hidden !important;
  }
  .gear-testing-form-section__form.pifyform.formloading {
    background-image: url(https://form-builder.pifyapp.com/assets/images/loading.gif?v=4.6);
    background-position: center 30px;
    background-size: 30px 30px;
    background-repeat: no-repeat;
  }
</style>

