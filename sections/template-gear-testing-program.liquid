<div class='text-center mt-24 mb-12 border-b border-gray-200 pb-8'>
  <h1
    id='gear-testing-program-header'
    class='text-3xl md:text-4xl font-bold text-gray-900 mb-4'
  >
    {{ section.settings.page_title }}
  </h1>
  <div class='text-gray-700 text-sm'>
    {{ section.settings.subtitle }}
  </div>
</div>


<div class='relative py-16 px-4 sm:px-6 lg:px-8'>
  <!-- Optional overlay for better text readability -->
  {% comment %} <div class='absolute inset-0 bg-black/30'></div> {% endcomment %}
  
  <div class='relative max-w-4xl mx-auto rounded-lg shadow-lg bg-white/95 backdrop-blur-sm p-8'>
    
    <!--pifyform-start-->

<!--pifyform-end-->

  </div>
</div>


{% schema %}
{
  "name": "Gear Testing Program",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "Gear Testing Program"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>We don’t test our gear in a boardroom.</p><p>We test it where it matters — in the field, on the trail, and under real conditions.</p><p>The Kestrel Knives Gear Testing Program is how we involve our community directly in shaping future knives and gear. Selected members will receive early access to upcoming products in exchange for real-world use, honest feedback, and content sharing.</p>"
    }
  ],
  "presets": [
    {
      "name": "Gear Testing Program"
    }
  ]
}
{% endschema %} 