  <img
    class='gear-testing-form-section__bg'
    src='{{ 'field_tester_program.jpg' | asset_url }}'
    alt=''
    loading='eager'
    fetchpriority='high'
  >
  <div class='gear-testing-form-section__overlay' aria-hidden='true'></div>

