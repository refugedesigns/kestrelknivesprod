{% schema %}
{
  "name": "Gear Testing Program",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "Kestrel Community Gear Testing Program"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>We don’t test our gear in a boardroom. We test it where it matters — in the field, on the trail, and under real conditions.</p><p>The Kestrel Knives Gear Testing Program is how we involve our community directly in shaping future knives and gear. Selected members will receive early access to upcoming products in exchange for real-world use, honest feedback, and content sharing.</p>"
    }
  ],
  "presets": [
    {
      "name": "Gear Testing Program"
    }
  ]
}
{% endschema %}
