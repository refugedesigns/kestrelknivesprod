<div class='max-w-4xl mx-auto text-center mt-4 mb-4 px-4 border-b border-gray-200 pb-4'>
  <h1
    id='gear-testing-program-header'
    class='text-3xl md:text-4xl font-bold text-gray-900 mb-8'
  >
    {{ section.settings.page_title }}
  </h1>
  <div class='text-gray-700 text-sm text-left pl-6 leading-relaxed gear-testing-subtitle mt-4'>
    {{ section.settings.subtitle }}
  </div>
</div>

<style>
  /* Preserve paragraph spacing for the rich text subtitle without affecting other sections */
  .gear-testing-subtitle p {
    margin: 0 0 0.4rem;
  }
  .gear-testing-subtitle p:last-child {
    margin-bottom: 0;
  }
</style>


<div class='px-4 sm:px-6 lg:px-8'>
  <!-- Optional overlay for better text readability -->
  {% comment %} <div class='absolute inset-0 bg-black/30'></div> {% endcomment %}
  
  <div class='max-w-4xl mx-auto rounded-lg shadow-lg bg-white/95 backdrop-blur-sm pt-0 mb-8'>
    
   
	
